<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@android:color/transparent">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/updateSheet"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="?attr/colorSurfaceContainer"
        app:cardCornerRadius="28dp"
        app:cardElevation="0dp"
        app:contentPaddingBottom="22dp"
        app:contentPaddingLeft="20dp"
        app:contentPaddingRight="20dp"
        app:contentPaddingTop="14dp"
        app:strokeColor="?attr/colorOutlineVariant"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <View
                android:layout_width="42dp"
                android:layout_height="4dp"
                android:layout_marginBottom="18dp"
                android:background="@drawable/bg_player_speed_handle" />

            <TextView
                android:id="@+id/updateTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:includeFontPadding="false"
                android:text="@string/update_available"
                android:textAppearance="?attr/textAppearanceHeadlineMedium"
                android:textStyle="bold" />

            <com.github.andreyasadchy.xtra.ui.view.SquiggleDividerView
                android:id="@+id/updateSquiggle"
                android:layout_width="match_parent"
                android:layout_height="28dp"
                android:layout_marginStart="34dp"
                android:layout_marginTop="12dp"
                android:layout_marginEnd="34dp"
                android:layout_marginBottom="14dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/updateVersionChip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_player_speed_preset"
                    android:includeFontPadding="false"
                    android:minHeight="34dp"
                    android:paddingStart="15dp"
                    android:paddingTop="8dp"
                    android:paddingEnd="15dp"
                    android:paddingBottom="8dp"
                    android:textAppearance="?attr/textAppearanceLabelLarge"
                    android:textColor="?attr/colorOnSurface"
                    tools:text="v2.6.0" />

                <TextView
                    android:id="@+id/updateDate"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="14dp"
                    android:layout_weight="1"
                    android:gravity="end"
                    android:textAppearance="?attr/textAppearanceBodyLarge"
                    android:textColor="?android:attr/textColorSecondary"
                    tools:text="2026-04-26" />
            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/releaseNotesCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                app:cardBackgroundColor="?attr/colorSurfaceContainerHigh"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="?attr/colorOutlineVariant"
                app:strokeWidth="1dp">

                <androidx.core.widget.NestedScrollView
                    android:id="@+id/releaseNotesScroll"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clipToPadding="false"
                    android:fillViewport="false"
                    android:overScrollMode="ifContentScrolls"
                    android:padding="16dp"
                    android:scrollbarStyle="outsideOverlay">

                    <TextView
                        android:id="@+id/releaseNotesText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textAppearance="?attr/textAppearanceBodyLarge"
                        android:textColor="?android:attr/textColorPrimary"
                        tools:text="## Bug fixes&#10;&#10;- Fixed updater prompt layout" />
                </androidx.core.widget.NestedScrollView>
            </com.google.android.material.card.MaterialCardView>

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="104dp"
                android:layout_marginTop="14dp">

                <LinearLayout
                    android:id="@+id/secondaryActions"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom|start"
                    android:gravity="start"
                    android:orientation="vertical">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/githubButton"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="wrap_content"
                        android:layout_height="44dp"
                        android:minWidth="0dp"
                        android:paddingStart="18dp"
                        android:paddingEnd="18dp"
                        android:text="@string/view_on_github"
                        android:textAllCaps="false"
                        android:textColor="?attr/colorOnSurface"
                        app:backgroundTint="@android:color/transparent"
                        app:cornerRadius="22dp"
                        app:icon="@drawable/baseline_open_in_new_24"
                        app:iconGravity="textStart"
                        app:iconPadding="8dp"
                        app:iconTint="?attr/colorOnSurface"
                        app:strokeColor="?attr/colorOutline" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/laterButton"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="44dp"
                        android:layout_marginTop="4dp"
                        android:minWidth="0dp"
                        android:paddingStart="18dp"
                        android:paddingEnd="18dp"
                        android:text="@string/later"
                        android:textAllCaps="false"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        app:cornerRadius="22dp" />
                </LinearLayout>

                <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
                    android:id="@+id/downloadButton"
                    android:layout_width="wrap_content"
                    android:layout_height="56dp"
                    android:layout_gravity="bottom|end"
                    android:minWidth="96dp"
                    android:paddingStart="20dp"
                    android:paddingEnd="24dp"
                    android:text="@string/download"
                    android:textAllCaps="false"
                    android:textColor="?attr/colorOnPrimaryContainer"
                    app:backgroundTint="?attr/colorPrimaryContainer"
                    app:elevation="6dp"
                    app:icon="@drawable/baseline_file_download_24"
                    app:iconPadding="10dp"
                    app:iconTint="?attr/colorOnPrimaryContainer"
                    app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Large" />
            </FrameLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
</FrameLayout>
