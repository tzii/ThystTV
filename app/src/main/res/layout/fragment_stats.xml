<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/coordinatorLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:colorBackground">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:liftOnScrollTargetViewId="@id/statsRecyclerView">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="?attr/actionBarSize"
            app:layout_scrollFlags="scroll|enterAlways"
            app:menu="@menu/stats_menu"
            app:title="@string/stats" />

        <HorizontalScrollView
            android:id="@+id/rangeScrollView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clipToPadding="false"
            android:paddingHorizontal="@dimen/stats_page_padding"
            android:paddingBottom="8dp"
            android:scrollbars="none"
            app:layout_scrollFlags="scroll|enterAlways">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/rangeContainer"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                app:cardBackgroundColor="@android:color/transparent"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeColor="?attr/colorOutline"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:id="@+id/rangeButtonRow"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/range7Days"
                        style="@style/StatsRangeButton"
                        android:checkable="true"
                        android:checked="true"
                        android:text="@string/stats_range_7_days" />

                    <View
                        android:layout_width="1dp"
                        android:layout_height="match_parent"
                        android:layout_marginVertical="8dp"
                        android:background="?attr/colorOutlineVariant" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/range30Days"
                        style="@style/StatsRangeButton"
                        android:checkable="true"
                        android:text="@string/stats_range_30_days" />

                    <View
                        android:layout_width="1dp"
                        android:layout_height="match_parent"
                        android:layout_marginVertical="8dp"
                        android:background="?attr/colorOutlineVariant" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/rangeAllTime"
                        style="@style/StatsRangeButton"
                        android:checkable="true"
                        android:text="@string/stats_range_all_time" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </HorizontalScrollView>

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/statsRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:padding="@dimen/stats_page_padding"
        app:layout_behavior="@string/appbar_scrolling_view_behavior"
        tools:listitem="@layout/item_stats_screen_time" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
